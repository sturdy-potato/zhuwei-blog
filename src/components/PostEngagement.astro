---
interface Props {
  slug: string;
  initialViews: number;
  initialLikes?: number;
  initialComments: number;
}

const { slug, initialViews, initialLikes = 0, initialComments } = Astro.props;
---

<section
  class="engagement-shell"
  data-post-engagement
  data-slug={slug}
  data-initial-views={initialViews}
  data-initial-likes={initialLikes}
  data-initial-comments={initialComments}
>
  <div class="engagement-summary">
    <div class="engagement-stat">
      <span class="engagement-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M2.75 12s3.6-6 9.25-6 9.25 6 9.25 6-3.6 6-9.25 6-9.25-6-9.25-6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
        </svg>
      </span>
      <div>
        <span class="engagement-label">阅读量</span>
        <strong data-stat-views>{initialViews.toLocaleString("zh-CN")}</strong>
      </div>
    </div>
    <div class="engagement-stat">
      <span class="engagement-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 20.25 4.95 13.4a4.75 4.75 0 0 1 6.72-6.71L12 7l.33-.31a4.75 4.75 0 1 1 6.72 6.71L12 20.25Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
      <div>
        <span class="engagement-label">点赞数</span>
        <strong data-stat-likes>{initialLikes.toLocaleString("zh-CN")}</strong>
      </div>
    </div>
    <div class="engagement-stat">
      <span class="engagement-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M5 6.75h14A2.25 2.25 0 0 1 21.25 9v7A2.25 2.25 0 0 1 19 18.25H10l-4.75 3v-3H5A2.25 2.25 0 0 1 2.75 16V9A2.25 2.25 0 0 1 5 6.75Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
      <div>
        <span class="engagement-label">评论数</span>
        <strong data-stat-comments>{initialComments.toLocaleString("zh-CN")}</strong>
      </div>
    </div>
    <button class="engagement-like" type="button" data-like-button>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M10.25 10.25V5.75A2.75 2.75 0 0 1 13 3h.22c.48 0 .86.38.88.86l.15 3.35 2.64.44A2.75 2.75 0 0 1 19.25 10.4l-.7 6.1A3 3 0 0 1 15.57 19H9.75a2.5 2.5 0 0 1-2.5-2.5v-6.25h3Zm-4.5 0H4.5A1.75 1.75 0 0 0 2.75 12v5.25C2.75 18.22 3.53 19 4.5 19h1.25v-8.75Z" fill="currentColor"></path>
      </svg>
      <span data-like-button-text>点赞支持作者</span>
    </button>
  </div>

  <div class="comment-shell">
    <div class="comment-header">
      <h2 class="comments-title">评论 <span data-comment-count-heading>/ {initialComments}</span></h2>
      <span class="comment-meta" data-comment-count-text>共 {initialComments} 条</span>
    </div>

    <div class="comment-empty-state">
      <div class="comment-empty-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
      <strong>还没有评论，来和作者聊聊吧</strong>
      <p>你可能是第一个留下评论的人</p>
    </div>

    <form class="comment-form" data-comment-form>
      <div class="comment-author-row">
        <div class="comment-avatar" aria-hidden="true">Z</div>
        <label class="comment-field comment-field-inline">
          <input name="nickname" maxlength="24" placeholder="怎么称呼你？" required aria-label="昵称" />
        </label>
      </div>
      <label class="comment-field">
        <textarea name="content" rows="5" maxlength="500" placeholder="写下你的想法…" required aria-label="评论内容"></textarea>
      </label>
      <div class="comment-actions">
        <div class="comment-tools" aria-hidden="true">
          <span class="comment-tool">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
              <line x1="9" y1="9" x2="9.01" y2="9"></line>
              <line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
          </span>
          <span class="comment-tool">
            <svg viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
          </span>
          <span class="comment-tool">
            <svg viewBox="0 0 24 24">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
          </span>
          <span class="comment-tool">
            <svg viewBox="0 0 24 24">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </span>
        </div>
        <div class="comment-action-right">
          <span class="comment-feedback" data-comment-feedback></span>
          <button type="submit" class="comment-submit">发表评论</button>
        </div>
      </div>
    </form>

    <div class="comment-list" data-comment-list></div>
  </div>
</section>

<script is:inline>
  // 中文注释：文章互动区统一在浏览器端拉取统计和评论，避免静态页面构建时依赖数据库。
  const engagementRoots = document.querySelectorAll("[data-post-engagement]");

  for (const root of engagementRoots) {
    if (!(root instanceof HTMLElement)) continue;

    const slug = root.dataset.slug;
    const initialViews = Number(root.dataset.initialViews || "0");
    const initialLikes = Number(root.dataset.initialLikes || "0");
    const initialComments = Number(root.dataset.initialComments || "0");
    if (!slug) continue;

    const viewsEl = root.querySelector("[data-stat-views]");
    const likesEl = root.querySelector("[data-stat-likes]");
    const commentsEl = root.querySelector("[data-stat-comments]");
    const commentCountTextEl = root.querySelector("[data-comment-count-text]");
    const commentCountHeadingEl = root.querySelector("[data-comment-count-heading]");
    const likeButton = root.querySelector("[data-like-button]");
    const likeButtonTextEl = root.querySelector("[data-like-button-text]");
    const commentForm = root.querySelector("[data-comment-form]");
    const feedbackEl = root.querySelector("[data-comment-feedback]");
    const listEl = root.querySelector("[data-comment-list]");
    const emptyStateEl = root.querySelector(".comment-empty-state");
    const query = new URLSearchParams({
      initialViews: String(initialViews),
      initialLikes: String(initialLikes),
      initialComments: String(initialComments)
    });
    const baseUrl = `/api/posts/${slug}`;

    const updateMetrics = (metrics) => {
      if (viewsEl) viewsEl.textContent = Number(metrics.views || 0).toLocaleString("zh-CN");
      if (likesEl) likesEl.textContent = Number(metrics.likes || 0).toLocaleString("zh-CN");
      if (commentsEl) commentsEl.textContent = Number(metrics.comment_count || 0).toLocaleString("zh-CN");
      if (commentCountTextEl) commentCountTextEl.textContent = `共 ${Number(metrics.comment_count || 0)} 条`;
      if (commentCountHeadingEl) commentCountHeadingEl.textContent = `/ ${Number(metrics.comment_count || 0)}`;
    };

    const renderComments = (comments) => {
      if (!listEl) return;
      if (emptyStateEl instanceof HTMLElement) {
        emptyStateEl.style.display = comments.length ? "none" : "flex";
      }
      if (!comments.length) {
        listEl.innerHTML = "";
        return;
      }

      listEl.innerHTML = comments
        .map(
          (comment) => `
            <article class="comment-item">
              <div class="comment-item-head">
                <strong>${escapeHtml(comment.nickname)}</strong>
                <span>${escapeHtml(comment.created_at)}</span>
              </div>
              <p>${escapeHtml(comment.content).replace(/\\n/g, "<br />")}</p>
            </article>
          `
        )
        .join("");
    };

    const loadStats = async () => {
      const response = await fetch(`${baseUrl}/stats?${query.toString()}`);
      if (!response.ok) return;
      const result = await response.json();
      if (result.ok) updateMetrics(result.metrics);
    };

    const loadComments = async () => {
      const response = await fetch(`${baseUrl}/comments`);
      if (!response.ok) return;
      const result = await response.json();
      if (result.ok) renderComments(result.comments || []);
    };

    const recordView = async () => {
      const response = await fetch(`${baseUrl}/view`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ initialViews, initialLikes, initialComments })
      });
      const result = await response.json();
      if (result.ok) updateMetrics(result.metrics);
      return result;
    };

    likeButton instanceof HTMLButtonElement &&
      likeButton.addEventListener("click", async () => {
        likeButton.disabled = true;
        const response = await fetch(`${baseUrl}/like`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ initialViews, initialLikes, initialComments })
        });
        const result = await response.json();
        if (result.ok) {
          updateMetrics(result.metrics);
          if (likeButtonTextEl) {
            likeButtonTextEl.textContent = result.liked ? "已点赞支持" : "点赞支持作者";
          }
        } else {
          likeButton.disabled = false;
        }
      });

    commentForm instanceof HTMLFormElement &&
      commentForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const formData = new FormData(commentForm);
        const payload = {
          nickname: String(formData.get("nickname") || ""),
          content: String(formData.get("content") || ""),
          initialViews,
          initialLikes,
          initialComments
        };

        if (feedbackEl) feedbackEl.textContent = "提交中…";

        const response = await fetch(`${baseUrl}/comments`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          if (feedbackEl) feedbackEl.textContent = result.message || "提交失败，请稍后再试";
          return;
        }

        if (feedbackEl) feedbackEl.textContent = "评论已发布";
        commentForm.reset();
        updateMetrics(result.metrics);
        await loadComments();
      });

    // 中文注释：先写入阅读事件再拉取统计，避免并发请求导致较旧的 stats 把最新阅读数覆盖掉。
    recordView()
      .catch(() => null)
      .then((result) => {
        if (!result?.ok) return loadStats().catch(() => {});
        return undefined;
      });
    loadComments().catch(() => {});
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }
</script>
