---
import type { CollectionEntry } from "astro:content";
import { getPostSlug, slugifyTag } from "../lib/blog";

interface Props {
  posts: CollectionEntry<"blog">[];
  tags?: string[];
  showTagCloud?: boolean;
  showTimeline?: boolean;
  variant?: "default" | "article" | "archive";
}

const { posts, tags = [], showTagCloud = false, showTimeline = false, variant = "default" } = Astro.props;
const hotPosts = [...posts].sort((a, b) => b.data.views - a.data.views).slice(0, 8);
const timelinePosts = posts.slice(0, 4);
const totalViews = posts.reduce((sum, post) => sum + post.data.views, 0);
const totalWords = posts.reduce((sum, post) => sum + (post.body ?? "").split(/[\s\p{P}]+/u).filter(Boolean).length, 0);

// 中文注释：根据数值大小智能选择 k / w / M 单位，避免小数据场景下都是 0.0w / 0.00M 的尴尬。
function formatCompact(value: number) {
  if (value < 1000) return value.toLocaleString("zh-CN");
  if (value < 10000) return `${(value / 1000).toFixed(1)}k`;
  if (value < 10_000_000) return `${(value / 10000).toFixed(1)}w`;
  return `${(value / 1_000_000).toFixed(2)}M`;
}

---

<aside class:list={["sidebar", variant === "article" && "article-sidebar", variant === "archive" && "archive-sidebar"]}>
  <div class="widget">
    <div class="widget-header">关于作者</div>
    <div class="author-widget">
      <div class="author-name">ZhuWei</div>
      <div class:list={["author-bio", variant === "article" && "article-author-bio"]}>
        前端工程师 / 开源爱好者
        {variant === "article" ? <br /> : " "}
        专注 React 生态 &amp; 架构设计
      </div>
      <div class="social-links">
        <a class="social-link" href="https://github.com" target="_blank" rel="noreferrer" title="GitHub" aria-label="GitHub">GitHub</a>
        <a class="social-link" href="https://juejin.cn" target="_blank" rel="noreferrer" title="掘金" aria-label="掘金">掘金</a>
        <a class="social-link" href="https://www.zhihu.com" target="_blank" rel="noreferrer" title="知乎" aria-label="知乎">知乎</a>
        <a class="social-link" href="mailto:hello@zhuwei.fun" title="邮箱" aria-label="邮箱">邮箱</a>
      </div>
      <div class="author-stats">
        <div class="author-stat">
          <div class="author-stat-val">{posts.length}</div>
          <div class="author-stat-label">文章</div>
        </div>
        <div class="author-stat">
          <div class="author-stat-val">{formatCompact(totalWords)}</div>
          <div class="author-stat-label">字数</div>
        </div>
        <div class="author-stat">
          <div class="author-stat-val">{formatCompact(totalViews)}</div>
          <div class="author-stat-label">阅读</div>
        </div>
      </div>
    </div>
  </div>

  <div class="widget">
    <div class="widget-header">热门文章</div>
    <ul class="rank-list">
      {hotPosts.map((post, index) => (
        <li class="rank-item">
          <span class="rank-num">{index + 1}.</span>
          <div class="rank-copy">
            <a class="rank-name" href={`/blog/${getPostSlug(post)}/`}>{post.data.title}</a>
            <span class="rank-count">{formatCompact(post.data.views)} 阅读</span>
          </div>
        </li>
      ))}
    </ul>
  </div>

  {showTagCloud && tags.length > 0 && (
    <div class="widget">
      <div class="widget-header">标签云</div>
      <div class="tag-cloud">
        {tags.map((tag) => (
          <a class="cloud-tag" href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
        ))}
      </div>
    </div>
  )}

  {showTimeline && timelinePosts.length > 0 && (
    <div class="widget">
      <div class="widget-header">最近动态</div>
      <ul class="timeline-list">
        {timelinePosts.map((post) => (
          <li class="timeline-item">
            <div>
              <div class="timeline-text"><strong>发布新文章</strong>「{post.data.title}」</div>
              <div class="timeline-date">{post.data.pubDate.toISOString().slice(0, 10)}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  )}
</aside>
