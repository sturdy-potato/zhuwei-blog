  <nav class="footer-links" aria-label="页脚链接">
    <a href="/about/">关于</a>
    <a href="/blog/">归档</a>
    <a href="/rss.xml">RSS</a>
    <a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a>
    <a href="mailto:hello@zhuwei.fun">邮箱</a>
  </nav>
  <p class="footer-copy">© 2026 ZhuWei Blog</p>
</footer>
