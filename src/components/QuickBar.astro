---
import { slugifyTag } from "../lib/blog";

interface Props {
  tags: string[];
  activeTag?: string;
  variant?: "default" | "archive";
  /** 首页内嵌：更轻、非吸顶 */
  density?: "default" | "compact";
}

const { tags, activeTag = "全部", variant = "default", density = "default" } = Astro.props;

const preferredTags = ["全部", "系统设计", "微前端", "工程化", "TypeScript", "React", "性能优化", "DevOps", "Docker", "K8s", "读书", "思考", "Web 安全"];
const allTags = [...new Set([...preferredTags, ...tags])];
---

<nav
  class:list={[
    "quick-bar",
    variant === "archive" && "archive-quick-bar",
    density === "compact" && "quick-bar--compact"
  ]}
  aria-label="标签导航"
>
  <p class="quick-bar-inner">
    {allTags.map((tag, index) => (
      <>
        {index > 0 && " · "}
        <a
          class:list={["quick-tag", activeTag === tag && "on"]}
          href={tag === "全部" ? "/" : `/tags/${slugifyTag(tag)}/`}
          data-filter={tag}
          aria-current={activeTag === tag ? "page" : undefined}
        >
          {tag}
        </a>
      </>
    ))}
  </p>
</nav>
