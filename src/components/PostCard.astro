---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatNumber, getPostSlug } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  isNew?: boolean;
}

const { post, isNew = false } = Astro.props;
const { data } = post;

// 中文注释：品类图标映射；在 markdown frontmatter 的 icon 字段里写关键字，这里渲染成统一风格的线性 SVG。
const iconPathMap: Record<string, string> = {
  Terminal: "M7 8l5 4-5 4M13 16h4",
  Server: "M4 5h16v4H4zM4 15h16v4H4zM7 7h.01M7 17h.01",
  Radio: "M8.59 14.52a4 4 0 0 1 0-5.04M15.41 9.48a4 4 0 0 1 0 5.04M5.64 17.95a8 8 0 0 1 0-11.9M18.36 6.05a8 8 0 0 1 0 11.9M12 13a1 1 0 1 0 0-2 1 1 0 0 0 0 2z",
  Code: "M10 8l-4 4 4 4M14 8l4 4-4 4",
  Book: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z",
  Zap: "M13 3L4 14h6l-1 7 9-11h-6z",
  Bulb: "M9 18h6M10 21h4M12 3a6 6 0 0 0-4 10c1 1 1 2 1 3h6c0-1 0-2 1-3a6 6 0 0 0-4-10z",
  Shield: "M12 3l8 3v6c0 4.5-3.5 8-8 9-4.5-1-8-4.5-8-9V6z",
  Package: "M21 8l-9 4-9-4 9-4 9 4zM3 8v8l9 4 9-4V8M12 12v8",
  Rocket: "M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2zM9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0",
  Cpu: "M4 4h16v16H4zM9 9h6v6H9zM9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2",
  Cloud: "M18 10a5 5 0 0 0-9.58-1.5A4 4 0 1 0 7 16h11a4 4 0 0 0 0-8z"
};

const iconPath = iconPathMap[data.icon] ?? iconPathMap.Code;
---

<a class="post-card" data-color={data.color} href={`/blog/${getPostSlug(post)}/`} data-tags={data.tags.join(",").toLowerCase()}>
  {isNew && <span class="post-new">NEW</span>}
  <div class:list={["post-icon-wrap", data.color]} aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d={iconPath} />
    </svg>
  </div>
  <div class="post-info">
    <div class="post-info-meta">
      <span class:list={["post-tag", data.color]}>{data.category}</span>
      <span class="post-date">{formatDate(data.pubDate)}</span>
    </div>
    <div class="post-title">{data.title}</div>
    <div class="post-excerpt">{data.excerpt}</div>
    <div class="post-footer">
      <span class="post-stat">👁 {formatNumber(data.views)}</span>
      <span class="post-stat">💬 {formatNumber(data.comments)}</span>
      <span class="post-stat">⏱ {data.minutes} min</span>
    </div>
  </div>
</a>
