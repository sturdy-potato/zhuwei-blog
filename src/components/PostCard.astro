---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatNumber, getPostSlug } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  isNew?: boolean;
  variant?: "default" | "archive";
}

const { post, isNew = false, variant = "default" } = Astro.props;
const { data } = post;
---

<article class:list={["post-card", variant === "archive" && "archive-post-card"]} data-tags={data.tags.join(",").toLowerCase()}>
  <h3 class="post-title">
    <a href={`/blog/${getPostSlug(post)}/`}>
      {isNew && "NEW · "}
      {data.title}
    </a>
  </h3>
  <p>{data.category} · {formatDate(data.pubDate)}</p>
  <p class="post-excerpt">{data.excerpt}</p>
  <p>阅读 {formatNumber(data.views)} · 评论 {formatNumber(data.comments)} · {data.minutes} 分钟</p>
</article>
