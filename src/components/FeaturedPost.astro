---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostSlug } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { data } = post;
---

<a class="featured-post" href={`/blog/${getPostSlug(post)}/`}>
  {data.pinned && <span class="featured-badge">PINNED</span>}
  <div class="featured-cover">
    <div class="featured-cover-grid"></div>
    <div class="featured-cover-glow"></div>
    <div class="featured-cube featured-cube-main"></div>
    <div class="featured-cube featured-cube-side"></div>
    <div class="featured-cover-symbol">&lt;/&gt;</div>
  </div>
  <div class="featured-body">
    <div class="featured-meta">
      <span class:list={["post-tag", data.color]}>{data.category}</span>
      <span class="post-date">{formatDate(data.pubDate)}</span>
    </div>
    <div class="featured-title">{data.title}</div>
    <div class="featured-excerpt">{data.excerpt}</div>
    <div class="post-footer">
      <span class="post-stat">👁 {data.views.toLocaleString("zh-CN")}</span>
      <span class="post-stat">💬 {data.comments.toLocaleString("zh-CN")}</span>
      <span class="post-stat">⏱ {data.minutes} min</span>
    </div>
  </div>
</a>
