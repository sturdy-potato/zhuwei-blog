---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostSlug } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  forcePinned?: boolean;
  variant?: "default" | "archive";
}

const { post, forcePinned = true, variant = "default" } = Astro.props;
const { data } = post;
const showPinned = forcePinned || data.pinned;
---

<article class:list={["featured-post", variant === "archive" && "archive-post"]}>
  <p>
    {showPinned && <strong>精选文章</strong>}
    {showPinned && " "}
    <a href={`/blog/${getPostSlug(post)}/`}>{data.title}</a>
  </p>
  <p>{data.category} · {formatDate(data.pubDate)}</p>
  <p>{data.excerpt}</p>
  <p>阅读 {data.views.toLocaleString("zh-CN")} · 评论 {data.comments.toLocaleString("zh-CN")} · {data.minutes} 分钟</p>
</article>
