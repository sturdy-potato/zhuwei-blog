---
import { slugifyTag } from "../lib/blog";

interface Props {
  activePath?: string;
  variant?: "default" | "article" | "archive";
}

const { activePath = "/", variant = "default" } = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "博客归档" },
  { href: `/tags/${slugifyTag("react")}/`, label: "前端开发" },
  { href: `/tags/${slugifyTag("系统设计")}/`, label: "系统设计" },
  { href: `/tags/${slugifyTag("工程化")}/`, label: "开源项目" },
  { href: `/tags/${slugifyTag("读书")}/`, label: "读书笔记" },
  { href: "/about/", label: "关于" }
];
---

<header class="site-header">
  <div class="nav-inner">
    <a class="logo" href="/">ZHUWEI<span class="logo-accent">.BLOG</span></a>
    <nav aria-label="主导航">
      <ul class="nav-links">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={activePath === item.href ? "page" : undefined}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="nav-actions">
      <div class="search-box">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-muted)"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>搜索文章、关键词...</span>
        <kbd class="search-kbd">⌘K</kbd>
      </div>
      <button class="icon-btn" aria-label="切换主题">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</header>
