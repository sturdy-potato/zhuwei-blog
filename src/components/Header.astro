---
interface Props {
  activePath?: string;
  searchPlaceholder?: string;
}

const { activePath = "/", searchPlaceholder = "搜索文章、关键词..." } = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "博客归档" },
  { href: "/tags/react/", label: "前端开发" },
  { href: "/tags/系统设计/", label: "系统设计" },
  { href: "/tags/工程化/", label: "开源项目" },
  { href: "/tags/读书/", label: "读书笔记" },
  { href: "/about/", label: "关于" }
];
---

<header class="site-header">
  <a class="logo" href="/">
    <span class="logo-mark" aria-hidden="true">
      <span class="logo-mark-core"></span>
    </span>
    <span class="logo-word">ZHUWEI</span>
    <span class="logo-blog">.BLOG</span>
  </a>
  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav" data-menu-toggle>
    菜单
  </button>
  <ul class="nav-links" id="site-nav" data-nav-links>
    {navItems.map((item) => (
      <li>
        <a href={item.href} class={activePath === item.href ? "active" : undefined}>{item.label}</a>
      </li>
    ))}
  </ul>
  <div class="header-right">
    <label class="search-bar">
      <span class="search-icon">⌕</span>
      <input type="text" placeholder={searchPlaceholder} data-search-input aria-label="搜索文章、关键词" />
      <span class="search-kbd">⌘K</span>
    </label>
    <button class="header-action" type="button" aria-label="刷新内容推荐">↻</button>
  </div>
</header>
