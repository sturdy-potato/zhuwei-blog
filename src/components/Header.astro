---
import { slugifyTag } from "../lib/blog";
import { SITE_CONFIG } from "../config/site";

interface Props {
  activePath?: string;
  variant?: "default" | "article" | "archive";
  // 中文注释：可由 BaseLayout 透传，覆盖默认搜索提示
  searchPlaceholder?: string;
}

const { activePath, variant = "default", searchPlaceholder } = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "博客" },
  { href: `/tags/${slugifyTag("AI工程")}/`, label: "AI 工程" },
  { href: `/tags/${slugifyTag("后端工程")}/`, label: "后端工程" },
  { href: `/tags/${slugifyTag("OpenClaw")}/`, label: "OpenClaw" },
  { href: "/about/", label: "关于" }
];

function normalizePath(path: string) {
  if (!path) return "/";
  if (path === "/") return path;
  return path.endsWith("/") ? path : `${path}/`;
}

const currentPath = normalizePath(activePath ?? Astro.url.pathname);

function isActive(href: string) {
  return normalizePath(href) === currentPath;
}
---

<header class="site-header">
  <div class="nav-inner">
    <a class="logo" href="/" aria-label={`${SITE_CONFIG.name} 首页`}><span class="logo-mark" aria-hidden="true">ZW</span>ZHUWEI<span class="logo-accent">.BLOG</span></a>
    <nav aria-label="主导航">
      <ul class="nav-links">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="nav-actions">
      <form class="search-box" action="/blog/" method="get" role="search">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-muted)"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <label class="sr-only" for="site-search">搜索文章</label>
        <input id="site-search" name="q" type="search" placeholder={searchPlaceholder ?? "搜索文章、关键词..."} autocomplete="off" />
        <button type="submit">搜索</button>
      </form>
      <a class="icon-btn nav-rss" href={SITE_CONFIG.rss} aria-label="RSS 订阅" title="RSS 订阅">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 11a8 8 0 0 1 8 8"/><path d="M5 5a14 14 0 0 1 14 14"/><circle cx="5" cy="19" r="1" fill="currentColor"/></svg>
      </a>
      <button class="icon-btn" data-theme-toggle aria-label="主题：跟随系统，点击切换" title="主题：跟随系统（点击切换）">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</header>
