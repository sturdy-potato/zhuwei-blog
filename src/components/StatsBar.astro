---
interface Props {
  totalPosts: number;
  totalWords: number;
  totalViews: number;
}

const { totalPosts, totalWords, totalViews } = Astro.props;
---

<section class="stats-bar" aria-label="站点统计">
  <ul class="stats-bar-inner">
    <li class="stat-item">文章：{totalPosts}</li>
    <li class="stat-item">字数：{totalWords.toLocaleString("zh-CN")}</li>
    <li class="stat-item">阅读：{totalViews.toLocaleString("zh-CN")}</li>
  </ul>
</section>
