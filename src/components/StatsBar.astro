---
interface Props {
  totalPosts: number;
  totalWords: number;
  totalViews: number;
}

const { totalPosts, totalWords, totalViews } = Astro.props;

const todayVisitors = 2481;
---

<div class="stats-bar">
  <div class="stats-bar-inner">
    <div class="stat-item">
      <span class="stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" />
          <polyline points="14 3 14 9 20 9" />
          <line x1="8" y1="13" x2="15" y2="13" />
          <line x1="8" y1="17" x2="13" y2="17" />
        </svg>
      </span>
      <span class="stat-label">文章总数</span>
      <span class="stat-val">{totalPosts}</span>
    </div>
    <div class="stat-item">
      <span class="stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" />
        </svg>
      </span>
      <span class="stat-label">总字数</span>
      <span class="stat-val">{totalWords.toLocaleString("zh-CN")}</span>
    </div>
    <div class="stat-item">
      <span class="stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
          <polyline points="16 7 22 7 22 13" />
        </svg>
      </span>
      <span class="stat-label">总阅读量</span>
      <span class="stat-val">{totalViews.toLocaleString("zh-CN")}</span>
      <span class="stat-up">▲ 5.1%</span>
    </div>
    <div class="stat-item">
      <span class="stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
      </span>
      <span class="stat-label">今日访客</span>
      <span class="stat-val" data-live-visitors>{todayVisitors.toLocaleString("zh-CN")}</span>
      <span class="stat-up">●</span>
    </div>
  </div>
</div>
