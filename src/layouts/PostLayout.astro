---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import PostEngagement from "../components/PostEngagement.astro";
import { formatDate, getPostSlug, getPublishedPosts, slugifyTag } from "../lib/blog";
import "../styles/detail.css";

interface Props {
  post: CollectionEntry<"blog">;
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, headings = [] } = Astro.props;
const posts = await getPublishedPosts();
const currentIndex = posts.findIndex((item) => item.id === post.id);
const prevPost = currentIndex >= 0 ? posts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const allTags = [...new Set(posts.flatMap((item) => item.data.tags))];
const relatedPosts = posts.filter((item) => item.id !== post.id).slice(0, 4);
const postUrl = new URL(`/blog/${getPostSlug(post)}/`, Astro.site).toString();
const imageUrl = new URL("/og-default.svg", Astro.site).toString();
const wordCount = (post.body ?? "").split(/\s+/u).filter(Boolean).length;
// 中文注释：文章结构化数据帮助搜索引擎识别标题、作者、发布时间和标签。
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  image: imageUrl,
  url: postUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl
  },
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: "ZhuWei",
    url: new URL("/about/", Astro.site).toString()
  },
  publisher: {
    "@type": "Organization",
    name: "ZHUWEI.BLOG",
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.svg", Astro.site).toString()
    }
  },
  articleSection: post.data.category,
  keywords: post.data.tags.join(", "),
  wordCount
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  activePath="/blog/"
  canonical={`/blog/${getPostSlug(post)}/`}
  type="article"
  jsonLd={articleJsonLd}
  pageVariant="article"
>
  <main class="article-page-main">
    <div class="article-layout">
      <div>
        <article class="article-shell">
          <header class="article-head">
            <div class="article-meta">
              <span class:list={["post-tag", post.data.color]}>{post.data.category}</span>
              <span class="article-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {formatDate(post.data.pubDate)}
              </span>
              <span class="article-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                {post.data.views.toLocaleString("zh-CN")} 阅读
              </span>
              <span class="article-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {post.data.minutes} 分钟
              </span>
              <div class="detail-tags detail-tags--meta">
                {post.data.tags.map((tag) => (
                  <a class="tag-pill" href={`/tags/${slugifyTag(tag)}/`}>#{tag}</a>
                ))}
              </div>
            </div>
            <h1 class="article-title">{post.data.title}</h1>
            <p class="article-summary">{post.data.excerpt}</p>
          </header>
          <div class="article-content">
            <slot />
          </div>
          {relatedPosts.length > 0 && (
            <section class="article-related" aria-label="你可能还感兴趣">
              <h2 class="article-related-title">你可能还感兴趣</h2>
              <ul class="article-related-list">
                {relatedPosts.map((item) => (
                  <li class="article-related-item">
                    <a href={`/blog/${getPostSlug(item)}/`}>{item.data.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          <PostEngagement
            slug={getPostSlug(post)}
            initialViews={post.data.views}
            initialLikes={0}
            initialComments={post.data.comments}
          />
        </article>
      </div>
      <Sidebar posts={posts} tags={allTags} headings={headings} showTagCloud={true} showTimeline={true} variant="article" />
    </div>
  </main>
  <script type="module" src="/scripts/copy-code.js"></script>
  <script type="module" src="/scripts/toc-active.js"></script>
</BaseLayout>
