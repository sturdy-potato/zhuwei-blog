---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import PostEngagement from "../components/PostEngagement.astro";
import Sidebar from "../components/Sidebar.astro";
import { formatDate, getPostSlug, getPublishedPosts } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const posts = await getPublishedPosts();
const currentIndex = posts.findIndex((item) => item.id === post.id);
const prevPost = currentIndex >= 0 ? posts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const allTags = [...new Set(posts.flatMap((item) => item.data.tags))];
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  activePath="/blog/"
  searchPlaceholder="搜索更多文章…"
  canonical={`/blog/${getPostSlug(post)}/`}
  type="article"
>
  <main class="page-main">
    <div class="home-grid">
      <article class="article-shell">
        <header class="article-head">
          <div class="article-meta">
            <span class:list={["post-tag", post.data.color]}>{post.data.category}</span>
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            <span class="post-stat">👁 {post.data.views.toLocaleString("zh-CN")}</span>
            <span class="post-stat">⏱ {post.data.minutes} min</span>
          </div>
          <h1 class="article-title">{post.data.title}</h1>
          <p class="article-summary">{post.data.excerpt}</p>
          <div class="detail-tags">
            {post.data.tags.map((tag) => (
              <a class="cloud-tag" href={`/tags/${tag.toLowerCase()}/`}>#{tag}</a>
            ))}
          </div>
        </header>
        <div class="article-content">
          <slot />
        </div>
        <PostEngagement
          slug={getPostSlug(post)}
          initialViews={post.data.views}
          initialLikes={0}
          initialComments={post.data.comments}
        />
        <nav class="article-nav">
          {prevPost ? (
            <a href={`/blog/${getPostSlug(prevPost)}/`}>
              <div class="article-nav-label">上一篇</div>
              <div class="article-nav-title">{prevPost.data.title}</div>
            </a>
          ) : <div></div>}
          {nextPost ? (
            <a href={`/blog/${getPostSlug(nextPost)}/`}>
              <div class="article-nav-label">下一篇</div>
              <div class="article-nav-title">{nextPost.data.title}</div>
            </a>
          ) : <div></div>}
        </nav>
      </article>
      <Sidebar posts={posts} tags={allTags} showTagCloud={true} showTimeline={true} />
    </div>
  </main>
</BaseLayout>
