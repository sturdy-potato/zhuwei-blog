---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../lib/blog";
import "../styles/detail.css";

const posts = await getPublishedPosts();
const totalWords = posts.reduce((sum, post) => sum + (post.body ?? "").split(/\s+/u).filter(Boolean).length, 0);
const totalViews = posts.reduce((sum, post) => sum + (Number(post.data.views) || 0), 0);
// 关于页统计：阅读为 0 时不展示，避免“冷启动尴尬”
const shouldShowViews = totalViews > 0;
---

<BaseLayout
  title="关于"
  description="关于 ZhuWei、博客写作方向与后续 Cloudflare + Astro 技术栈规划。"
  activePath="/about/"
  canonical="/about/"
>
  <main class="article-page-main">
    <div class="article-layout article-layout--single">
      <div>
        <article class="article-shell">
          <header class="article-head">
            <div class="article-meta">
              <span class="post-tag cyan">关于</span>
              <span class="article-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                持续更新
              </span>
            </div>
            <h1 class="article-title">关于这个博客：Token 剩余产物</h1>
            <p class="article-summary">这个博客的更新频率怎么定？看余额：Cursor 月额度还在、CodeX 周额度没清零。</p>
          </header>
          <div class="article-content">
            <h2>更新算法</h2>
            <p>
              很多人问我（其实并没人问）什么时候更新。<br />
              看余额：Cursor 月额度还在、CodeX 周额度没清零，我就拉着 AI 一起写点东西，顺便研究下“代码为什么又跑不起来”的玄学。
            </p>
            <p>
              我更新得勤：要么很闲，要么 Token还剩很多<br />
              我突然消失：只有一个原因：Token不够用了
            </p>

            <blockquote>“用代码书写，以文字沉淀”——其实真相是：“用 AI 吹水，以 Token 续命”。</blockquote>

            <h2>关于作者</h2>
            <section class="about-author-card" aria-label="作者信息">
              <div class="about-author-top">
                <div class="about-author-avatar" aria-hidden="true">ZW</div>
                <div class="about-author-title">
                  <div class="about-author-name">
                    <strong>ZhuWei</strong>
                    <span class="post-tag cyan about-author-tag">博主</span>
                  </div>
                  <div class="about-author-role">后端打工人 / 偶尔探索宇宙</div>
                  <div class="about-author-spec">PHP · Go · Python｜随手记点东西；写错了就错了</div>
                </div>
              </div>

              <div class="about-author-stats" role="list">
                <div class="about-stat" role="listitem">
                  <div class="about-stat-value">{posts.length.toLocaleString("zh-CN")}</div>
                  <div class="about-stat-label">文章</div>
                </div>
                <div class="about-stat" role="listitem">
                  <div class="about-stat-value">{totalWords.toLocaleString("zh-CN")}</div>
                  <div class="about-stat-label">字数</div>
                </div>
                {shouldShowViews && (
                  <div class="about-stat" role="listitem">
                    <div class="about-stat-value">{totalViews.toLocaleString("zh-CN")}</div>
                    <div class="about-stat-label">阅读</div>
                  </div>
                )}
              </div>
            </section>
          </div>
        </article>
      </div>
    </div>
  </main>
</BaseLayout>
