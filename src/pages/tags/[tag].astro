---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedPost from "../../components/FeaturedPost.astro";
import PostCard from "../../components/PostCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getPublishedPosts, slugifyTag } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const { tag: tagSlug } = Astro.params;
const posts = await getPublishedPosts();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const filteredPosts = posts.filter((post) => post.data.tags.some((item) => slugifyTag(item) === tagSlug));
const featuredTagPost = filteredPosts.find((post) => post.data.pinned) ?? filteredPosts[0];
---

<BaseLayout
  title={`${tag} 标签`}
  description={`浏览所有与 ${tag} 相关的技术文章。`}
  canonical={`/tags/${slugifyTag(tag)}/`}
  pageVariant="archive"
>
  <div class="page-wrap">
    <main>
      <div class="hp-section-title" style="margin-bottom:12px;">
        标签：{tag}
        <span style="font-size:13px;font-weight:400;color:var(--text-muted);margin-left:auto;">共 {filteredPosts.length} 篇相关文章</span>
      </div>
      <p style="font-size:13px;color:var(--text-muted);margin:0 0 20px;">
        围绕「{tag}」这个主题，把相关文章聚合到一个可索引、可浏览、可持续扩展的独立内容入口中。
      </p>

      {featuredTagPost && <FeaturedPost post={featuredTagPost} forcePinned={false} variant="archive" />}

      <div class="hp-article-list">
        {filteredPosts.map((post, index) => <PostCard post={post} isNew={index === 0} variant="archive" />)}
      </div>
    </main>

    <Sidebar posts={posts} tags={tags} showTagCloud={true} showTimeline={true} variant="archive" />
  </div>
</BaseLayout>
