---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedPost from "../../components/FeaturedPost.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, slugifyTag } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const { tag: tagSlug } = Astro.params;
const posts = await getPublishedPosts();
const filteredPosts = posts.filter((post) => post.data.tags.some((item) => slugifyTag(item) === tagSlug));
const featuredTagPost = filteredPosts.find((post) => post.data.pinned) ?? filteredPosts[0];
---

<BaseLayout
  title={`${tag} 标签`}
  description={`浏览所有与 ${tag} 相关的技术文章。`}
  canonical={`/tags/${slugifyTag(tag)}/`}
  pageVariant="archive"
>
  <div class="page-wrap page-wrap--single">
    <main>
      <div class="hp-section-title" style="margin-bottom:12px;">
        标签：{tag}
        <span style="font-size:13px;font-weight:400;color:var(--text-muted);margin-left:auto;">共 {filteredPosts.length} 篇相关文章</span>
      </div>
      <p style="font-size:13px;color:var(--text-muted);margin:0 0 20px;">
        围绕「{tag}」这个主题，把相关文章聚合到一个可索引、可浏览、可持续扩展的独立内容入口中。
      </p>

      {featuredTagPost && <FeaturedPost post={featuredTagPost} forcePinned={false} variant="archive" />}

      <div class="hp-article-list">
        {filteredPosts.map((post, index) => <PostCard post={post} isNew={index === 0} variant="archive" />)}
      </div>
    </main>
  </div>
</BaseLayout>

<script is:inline>
  // 中文注释：标签页在客户端批量拉取 D1 统计，保证列表阅读和评论显示真实值。
  const tagSlugNodes = document.querySelectorAll("[data-post-slug]");
  const tagSlugs = Array.from(tagSlugNodes)
    .map((node) => (node instanceof HTMLElement ? node.dataset.postSlug : ""))
    .filter(Boolean);

  if (tagSlugs.length) {
    const uniqueTagSlugs = [...new Set(tagSlugs)];
    fetch(`/api/posts/metrics?slugs=${encodeURIComponent(uniqueTagSlugs.join(","))}`)
      .then((response) => response.json())
      .then((result) => {
        if (!result?.ok || !result.metrics) return;
        const metrics = result.metrics;

        for (const slug of uniqueTagSlugs) {
          const item = metrics[slug];
          if (!item) continue;

          const viewNodes = document.querySelectorAll(`[data-post-views="${slug}"]`);
          for (const viewNode of viewNodes) {
            if (!(viewNode instanceof HTMLElement)) continue;
            const icon = viewNode.querySelector("svg");
            viewNode.textContent = Number(item.views || 0).toLocaleString("zh-CN");
            if (icon) viewNode.prepend(icon);
          }

          const commentNodes = document.querySelectorAll(`[data-post-comments="${slug}"]`);
          for (const commentNode of commentNodes) {
            if (!(commentNode instanceof HTMLElement)) continue;
            const icon = commentNode.querySelector("svg");
            commentNode.textContent = Number(item.comment_count || 0).toLocaleString("zh-CN");
            if (icon) commentNode.prepend(icon);
          }
        }
      })
      .catch(() => {});
  }
</script>
