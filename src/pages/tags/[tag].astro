---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategorySidebar from "../../components/CategorySidebar.astro";
import PostList from "../../components/PostList.astro";
import { getCategoryStats, getPublishedPosts, slugifyTag } from "../../lib/blog";
import "../../styles/home.css";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  // 中文注释：同一路由承载一级分类、二级分类和普通标签，保证旧标签入口与新侧栏链接都可访问。
  const tags = [...new Set(posts.flatMap((post) => [...post.data.tags, post.data.section, post.data.category]))];
  return tags.map((tag) => ({ params: { tag: slugifyTag(tag) }, props: { tag } }));
}

const { tag } = Astro.props;
const { tag: tagSlug = "" } = Astro.params;
const posts = await getPublishedPosts();
const categories = getCategoryStats(posts);
const matchesSection = posts.some((post) => slugifyTag(post.data.section) === tagSlug);
const matchesCategory = posts.some((post) => slugifyTag(post.data.category) === tagSlug);
const filteredPosts = posts.filter((post) => {
  // 中文注释：分类名称与普通标签同名时优先按分类筛选，保证侧栏显示数量与落地页文章数量一致。
  if (matchesSection) return slugifyTag(post.data.section) === tagSlug;
  if (matchesCategory) return slugifyTag(post.data.category) === tagSlug;
  const normalizedTags = post.data.tags.map((item) => slugifyTag(item));
  return normalizedTags.includes(tagSlug);
});
const activeCategory = categories.find((category) => category.slug === tagSlug)?.name ?? tag;
---

<BaseLayout
  title={`${tag} 标签`}
  description={`浏览所有与 ${tag} 相关的技术文章。`}
  canonical={`/tags/${slugifyTag(tag)}/`}
  pageVariant="archive"
>
  <main class="platform-page">
    <div class="platform-layout">
      <CategorySidebar categories={categories} totalPosts={posts.length} activeCategory={activeCategory} allHref="/blog/" />
      <section class="platform-main article-feed" aria-labelledby="tag-title">
        <header class="feed-header feed-header--large">
          <div>
            <span class="feed-eyebrow">TOPIC</span>
            <h1 id="tag-title">{tag}</h1>
            <p>围绕「{tag}」整理的相关文章</p>
          </div>
          <span>共 {filteredPosts.length} 篇</span>
        </header>
        <PostList posts={filteredPosts} emptyText={`暂时没有与「${tag}」相关的文章`} />
      </section>
    </div>
  </main>
  <script is:inline type="module" src="/scripts/post-metrics.js"></script>
</BaseLayout>
