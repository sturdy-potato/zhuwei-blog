---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedPost from "../../components/FeaturedPost.astro";
import PostCard from "../../components/PostCard.astro";
import { getPinnedPost, getPublishedPosts } from "../../lib/blog";

const posts = await getPublishedPosts();
const pinned = await getPinnedPost();
---

<BaseLayout
  title="博客归档"
  description="按时间线浏览 ZhuWei 的全部文章，涵盖前端开发、系统设计、工程化与读书思考。"
  activePath="/blog/"
  canonical="/blog/"
  pageVariant="archive"
>
  <div class="page-wrap page-wrap--single">
    <main>
      <div class="hp-section-title" style="margin-bottom:20px;">
        博客归档
        <span style="font-size:13px;font-weight:400;color:var(--text-muted);margin-left:auto;">共 {posts.length} 篇文章</span>
      </div>

      {pinned && <FeaturedPost post={pinned} variant="archive" />}

      <div class="hp-article-list">
        {posts.map((post, index) => <PostCard post={post} isNew={index === 0} variant="archive" />)}
      </div>
    </main>
  </div>
</BaseLayout>

<script is:inline>
  // 中文注释：归档页在客户端批量拉取 D1 统计，覆盖 frontmatter 初始阅读与评论。
  const archiveSlugNodes = document.querySelectorAll("[data-post-slug]");
  const archiveSlugs = Array.from(archiveSlugNodes)
    .map((node) => (node instanceof HTMLElement ? node.dataset.postSlug : ""))
    .filter(Boolean);

  if (archiveSlugs.length) {
    const uniqueArchiveSlugs = [...new Set(archiveSlugs)];
    fetch(`/api/posts/metrics?slugs=${encodeURIComponent(uniqueArchiveSlugs.join(","))}`)
      .then((response) => response.json())
      .then((result) => {
        if (!result?.ok || !result.metrics) return;
        const metrics = result.metrics;

        for (const slug of uniqueArchiveSlugs) {
          const item = metrics[slug];
          if (!item) continue;

          const viewNodes = document.querySelectorAll(`[data-post-views="${slug}"]`);
          for (const viewNode of viewNodes) {
            if (!(viewNode instanceof HTMLElement)) continue;
            const icon = viewNode.querySelector("svg");
            viewNode.textContent = Number(item.views || 0).toLocaleString("zh-CN");
            if (icon) viewNode.prepend(icon);
          }

          const commentNodes = document.querySelectorAll(`[data-post-comments="${slug}"]`);
          for (const commentNode of commentNodes) {
            if (!(commentNode instanceof HTMLElement)) continue;
            const icon = commentNode.querySelector("svg");
            commentNode.textContent = Number(item.comment_count || 0).toLocaleString("zh-CN");
            if (icon) commentNode.prepend(icon);
          }
        }
      })
      .catch(() => {});
  }
</script>
