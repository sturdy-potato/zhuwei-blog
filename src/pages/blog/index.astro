---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategorySidebar from "../../components/CategorySidebar.astro";
import PostList from "../../components/PostList.astro";
import { getCategoryStats, getPostSlug, getPublishedPosts } from "../../lib/blog";
import "../../styles/home.css";

const posts = await getPublishedPosts();
const categories = getCategoryStats(posts);
const hotPosts = [...posts].sort((a, b) => b.data.views - a.data.views);
// 中文注释：归档页声明文章集合关系，搜索参数只做前端过滤，不改变 canonical。
const archiveJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "博客归档",
  description: "按时间浏览 ZhuWei 的全部技术文章。",
  url: new URL("/blog/", Astro.site).toString(),
  hasPart: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    url: new URL(`/blog/${getPostSlug(post)}/`, Astro.site).toString(),
    datePublished: post.data.pubDate.toISOString()
  }))
};
---

<BaseLayout
  title="博客归档"
  description="按时间浏览 ZhuWei 的全部技术文章，涵盖后端工程、网络协议、AI 自动化与数码折腾。"
  activePath="/blog/"
  canonical="/blog/"
  jsonLd={archiveJsonLd}
  pageVariant="archive"
>
  <main class="platform-page">
    <div class="platform-layout">
      <CategorySidebar categories={categories} totalPosts={posts.length} hotPosts={hotPosts} allHref="/blog/" />
      <section class="platform-main article-feed" aria-labelledby="archive-title">
        <header class="feed-header feed-header--large">
          <div>
            <span class="feed-eyebrow">ARCHIVE</span>
            <h1 id="archive-title">博客归档</h1>
            <p data-search-result>按发布时间浏览全部文章</p>
          </div>
          <span>共 {posts.length} 篇</span>
        </header>
        <PostList posts={posts} />
        <div class="list-empty-state" data-search-empty hidden>没有找到匹配的文章，请更换关键词后重试</div>
      </section>
    </div>
  </main>
  <script is:inline type="module" src="/scripts/post-metrics.js"></script>
  <script is:inline type="module" src="/scripts/archive-search.js"></script>
</BaseLayout>
