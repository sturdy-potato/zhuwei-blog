---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";
import QuickBar from "../components/QuickBar.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Sidebar from "../components/Sidebar.astro";
import StatsBar from "../components/StatsBar.astro";
import { getPinnedPost, getPublishedPosts, groupPostsBySection } from "../lib/blog";

const posts = await getPublishedPosts();
const pinned = await getPinnedPost();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const sections = groupPostsBySection(posts.filter((post) => !post.data.pinned));
const totalWords = posts.reduce((sum, post) => sum + (post.body ?? "").split(/\s+/u).filter(Boolean).length, 0);
const totalViews = posts.reduce((sum, post) => sum + post.data.views, 0);
---

<BaseLayout
  title="技术笔记与思考"
  description="一个专注于前端开发、系统设计与开源技术的个人博客。记录技术成长与思考。"
  activePath="/"
>
  <div class="page-home">
    <Hero />
    <main class="page-main page-main--home" id="main-content">
      <div class="home-grid">
        <div class="content content-column">
          {pinned && <FeaturedPost post={pinned} />}
          <StatsBar totalPosts={posts.length} totalWords={totalWords} totalViews={totalViews} />
          <QuickBar tags={tags} density="compact" />
          {Object.entries(sections).map(([section, sectionPosts]) => (
            <section>
              <SectionHeader title={section} />
              <div class="post-grid">
                {sectionPosts.map((post, index) => (
                  <PostCard post={post} isNew={section === "最新文章" && index === 0} />
                ))}
              </div>
            </section>
          ))}
        </div>
        <Sidebar posts={posts} />
      </div>
    </main>
  </div>
</BaseLayout>
