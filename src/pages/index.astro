---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthorOverview from "../components/AuthorOverview.astro";
import CategorySidebar from "../components/CategorySidebar.astro";
import PostList from "../components/PostList.astro";
import { getCategoryStats, getPostSlug, getPublishedPosts } from "../lib/blog";
import "../styles/home.css";

const posts = await getPublishedPosts();
const categories = getCategoryStats(posts);
const totalWords = posts.reduce((sum, post) => sum + (post.body ?? "").split(/\s+/u).filter(Boolean).length, 0);
const totalViews = posts.reduce((sum, post) => sum + post.data.views, 0);
const hotPosts = [...posts].sort((a, b) => b.data.views - a.data.views);
const siteUrl = new URL("/", Astro.site).toString();

// 中文注释：首页结构化数据继续使用完整文章集合，UI 改造不改变搜索引擎可识别的文章关系。
const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "ZHUWEI.BLOG",
    url: siteUrl,
    description: "一个专注于后端工程、网络协议与 AI 自动化的个人博客。",
    inLanguage: "zh-CN"
  },
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "ZHUWEI.BLOG",
    url: siteUrl,
    blogPost: posts.slice(0, 10).map((post) => ({
      "@type": "BlogPosting",
      headline: post.data.title,
      url: new URL(`/blog/${getPostSlug(post)}/`, Astro.site).toString(),
      datePublished: post.data.pubDate.toISOString()
    }))
  }
];
---

<BaseLayout
  title="技术笔记与思考"
  description="一个专注于后端工程、网络协议与 AI 自动化的个人博客，用 PHP / Go / Python 记录真实项目中的问题与方案。"
  activePath="/"
  canonical="/"
  jsonLd={homeJsonLd}
  searchPlaceholder="搜索文章、分类或标签"
>
  <main class="platform-page">
    <div class="platform-layout">
      <CategorySidebar categories={categories} totalPosts={posts.length} hotPosts={hotPosts} />
      <div class="platform-main">
        <AuthorOverview
          postCount={posts.length}
          categoryCount={categories.length}
          totalViews={totalViews}
          totalWords={totalWords}
        />
        <section class="article-feed" aria-labelledby="latest-posts-title">
          <header class="feed-header">
            <div>
              <h2 id="latest-posts-title">最新文章</h2>
              <p>记录真实项目中的问题、判断与解决方案</p>
            </div>
            <span>共 {posts.length} 篇</span>
          </header>
          <PostList posts={posts} />
        </section>
      </div>
    </div>
  </main>
  <script is:inline type="module" src="/scripts/post-metrics.js"></script>
</BaseLayout>
